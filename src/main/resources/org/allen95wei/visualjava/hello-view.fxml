<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<!--
    歡迎頁面根容器 / Welcome page root container
    VBox 會把裡面的元件垂直排列 / VBox arranges child elements vertically
-->
<VBox alignment="CENTER"
      spacing="25.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.allen95wei.visualjava.HelloController"
      prefWidth="1200.0"
      prefHeight="700.0"
      style="-fx-background-color: linear-gradient(to bottom right, #E9FCFF, #86D9FF, #D8FFE8);">

    <!--
        內距設定 / Padding setting
        讓畫面邊緣和內容之間保留空間 / Keeps space between the screen edge and content
    -->
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!--
        歡迎標題 / Welcome title
        顯示應用程式名稱 / Shows the application name
    -->
    <Label fx:id="welcomeText"
           text="Visual Java Editor"
           alignment="CENTER"
           textAlignment="CENTER"
           style="-fx-font-family: 'Segoe UI';
                  -fx-font-size: 44;
                  -fx-font-weight: bold;
                  -fx-text-fill: #0B4A6F;
                  -fx-effect: dropshadow(gaussian, rgba(255,255,255,0.95), 10, 0.6, 0, 2);" />

    <!--
        進入專案按鈕 / Enter project button
        點擊後會呼叫 HelloController 裡的 handleHelloButtonClick 方法
        When clicked, it calls the handleHelloButtonClick method in HelloController
    -->
    <Button text="Hello Project!"
            onAction="#handleHelloButtonClick"
            style="-fx-font-family: 'Segoe UI';
                   -fx-font-size: 20;
                   -fx-font-weight: bold;
                   -fx-text-fill: white;
                   -fx-background-color:
                       linear-gradient(to bottom, rgba(255,255,255,0.90), rgba(255,255,255,0.15)),
                       linear-gradient(to bottom, #72ECFF, #1F9BFF);
                   -fx-background-radius: 30;
                   -fx-border-radius: 30;
                   -fx-border-color: rgba(255,255,255,0.95);
                   -fx-border-width: 2;
                   -fx-padding: 14 46 14 46;
                   -fx-effect: dropshadow(gaussian, rgba(0,200,255,0.90), 28, 0.45, 0, 0);" />

</VBox>