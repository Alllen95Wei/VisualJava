<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.allen95wei.visualjava.EditorController"
            prefWidth="1200.0"
            prefHeight="700.0"
            style="-fx-background-color: linear-gradient(to bottom right, #E9FCFF, #86D9FF, #D8FFE8);">

    <!-- 上方工具列 / Top toolbar: project title and main action buttons -->
    <Pane fx:id="topBar"
          layoutX="0.0"
          layoutY="0.0"
          prefWidth="1200.0"
          prefHeight="56.0"
          style="-fx-background-color:
                    linear-gradient(to bottom, rgba(255,255,255,0.90), rgba(255,255,255,0.45));
                 -fx-border-color: rgba(255,255,255,0.95);
                 -fx-border-width: 0 0 2 0;
                 -fx-effect: dropshadow(gaussian, rgba(0,150,255,0.25), 14, 0.3, 0, 2);">

        <!-- 專案標題 / Project title -->
        <Label text="Visual Java Editor"
               layoutX="24.0"
               layoutY="13.0"
               style="-fx-font-family: 'Segoe UI';
                      -fx-font-size: 22;
                      -fx-font-weight: bold;
                      -fx-text-fill: #0B4A6F;" />

        <!-- 執行按鈕 / Run button: visual placeholder for future run function -->
        <Button text="Run"
                layoutX="980.0"
                layoutY="12.0"
                prefWidth="80.0"
                prefHeight="32.0"
                style="-fx-font-family: 'Segoe UI';
                       -fx-font-size: 14;
                       -fx-font-weight: bold;
                       -fx-text-fill: white;
                       -fx-background-color:
                           linear-gradient(to bottom, rgba(255,255,255,0.80), rgba(255,255,255,0.15)),
                           linear-gradient(to bottom, #72ECFF, #1F9BFF);
                       -fx-background-radius: 18;
                       -fx-border-radius: 18;
                       -fx-border-color: white;
                       -fx-border-width: 1.5;" />

        <!-- 儲存按鈕 / Save button: visual placeholder for future save function -->
        <Button text="Save"
                layoutX="1070.0"
                layoutY="12.0"
                prefWidth="80.0"
                prefHeight="32.0"
                style="-fx-font-family: 'Segoe UI';
                       -fx-font-size: 14;
                       -fx-font-weight: bold;
                       -fx-text-fill: #0B4A6F;
                       -fx-background-color: rgba(255,255,255,0.75);
                       -fx-background-radius: 18;
                       -fx-border-radius: 18;
                       -fx-border-color: rgba(255,255,255,0.95);
                       -fx-border-width: 1.5;" />
    </Pane>

    <!-- 中間工作區 / Center workspace: white area for users to place blocks -->
    <Pane fx:id="workspace"
          layoutX="220.0"
          layoutY="70.0"
          prefWidth="400.0"
          prefHeight="570.0"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #7ADFFF;
                 -fx-border-width: 0 2 0 2;" />

    <!-- 右邊執行結果區 / Right result area: white area for showing execution results -->
    <Pane fx:id="resultPane"
          layoutX="640.0"
          layoutY="70.0"
          prefWidth="500.0"
          prefHeight="570.0"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #7ADFFF;
                 -fx-border-width: 0 2 0 2;">

        <!-- 執行結果標題 / Result title label -->
        <Label fx:id="resultLabel"
               text="執行結果區"
               layoutX="170.0"
               layoutY="25.0"
               style="-fx-font-family: 'Segoe UI';
                      -fx-font-size: 24;
                      -fx-font-weight: bold;
                      -fx-text-fill: #0B4A6F;" />

    </Pane>

    <!-- 左邊工具欄 / Left toolbox: area for block templates -->
    <VBox fx:id="toolbox"
          layoutX="0.0"
          layoutY="70.0"
          spacing="15.0"
          prefWidth="200.0"
          prefHeight="570.0"
          style="-fx-background-color: #FFFFFF;
                 -fx-border-color: #7ADFFF;
                 -fx-border-width: 0 2 0 0;
                 -fx-padding: 20;" />

    <!-- 下方狀態列 / Bottom status bar: simple status information -->
    <Pane fx:id="bottomBar"
          layoutX="0.0"
          layoutY="660.0"
          prefWidth="1200.0"
          prefHeight="40.0"
          style="-fx-background-color:
                    linear-gradient(to bottom, rgba(255,255,255,0.55), rgba(255,255,255,0.85));
                 -fx-border-color: rgba(255,255,255,0.95);
                 -fx-border-width: 2 0 0 0;">

        <!-- 狀態文字 / Status text -->
        <Label text="Ready"
               layoutX="24.0"
               layoutY="10.0"
               style="-fx-font-family: 'Segoe UI';
                      -fx-font-size: 14;
                      -fx-text-fill: #0B4A6F;" />

        <!-- 縮放資訊 / Zoom information -->
        <Label text="Zoom: 100%"
               layoutX="1060.0"
               layoutY="10.0"
               style="-fx-font-family: 'Segoe UI';
                      -fx-font-size: 14;
                      -fx-text-fill: #0B4A6F;" />
    </Pane>

    <!-- 箭頭圖層 / Arrow layer: transparent layer for connection lines -->
    <Pane fx:id="arrowLayer"
          layoutX="0.0"
          layoutY="0.0"
          prefWidth="1200.0"
          prefHeight="700.0"
          pickOnBounds="false"
          style="-fx-background-color: transparent;" />

    <!-- 積木圖層 / Blocks layer: transparent layer for dragged blocks -->
    <Pane fx:id="blocksLayer"
          layoutX="0.0"
          layoutY="0.0"
          prefWidth="1200.0"
          prefHeight="700.0"
          pickOnBounds="false"
          style="-fx-background-color: transparent;" />

</AnchorPane>