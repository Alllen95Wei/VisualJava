<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.allen95wei.visualjava.EditorController"
            prefWidth="1200.0"
            prefHeight="700.0"
            style="-fx-background-color: linear-gradient(to bottom right, #E9FCFF, #86D9FF, #D8FFE8);">

    <!-- 上方工具列 / Top toolbar -->
    <Pane fx:id="topBar"
          layoutX="0.0"
          layoutY="0.0"
          prefWidth="1200.0"
          prefHeight="56.0"
          style="-fx-background-color:
                    linear-gradient(to bottom, rgba(255,255,255,0.90), rgba(255,255,255,0.45));
                 -fx-border-color: rgba(255,255,255,0.95);
                 -fx-border-width: 0 0 1 0;">

        <!-- App title / 應用程式標題 -->
        <Label text="Visual Java Editor"
               layoutX="24.0"
               layoutY="13.0"
               style="-fx-font-family: 'Segoe UI';
                      -fx-font-size: 22;
                      -fx-font-weight: bold;
                      -fx-text-fill: #0B4A6F;" />

        <!-- Run button / 執行按鈕 -->
        <!-- onAction 會呼叫 EditorController 裡的 handleRunBlocks() -->
        <!-- onAction calls handleRunBlocks() inside EditorController -->
        <Button text="Run"
                onAction="#handleRunBlocks"
                layoutX="980.0"
                layoutY="12.0"
                prefWidth="80.0"
                prefHeight="32.0"
                style="-fx-font-family: 'Segoe UI';
                       -fx-font-size: 14;
                       -fx-font-weight: bold;
                       -fx-text-fill: white;
                       -fx-background-color:
                           linear-gradient(to bottom, rgba(255,255,255,0.80), rgba(255,255,255,0.15)),
                           linear-gradient(to bottom, #72ECFF, #1F9BFF);
                       -fx-background-radius: 18;
                       -fx-border-radius: 18;
                       -fx-border-color: white;
                       -fx-border-width: 1.5;" />

        <!-- Save button / 儲存按鈕 -->
        <!-- 現在先只做 UI，功能之後再接 / UI only for now, function can be connected later -->
        <Button text="Save"
                layoutX="1070.0"
                layoutY="12.0"
                prefWidth="80.0"
                prefHeight="32.0"
                style="-fx-font-family: 'Segoe UI';
                       -fx-font-size: 14;
                       -fx-font-weight: bold;
                       -fx-text-fill: #0B4A6F;
                       -fx-background-color: rgba(255,255,255,0.75);
                       -fx-background-radius: 18;
                       -fx-border-radius: 18;
                       -fx-border-color: rgba(255,255,255,0.95);
                       -fx-border-width: 1.5;" />
    </Pane>

    <!-- 左邊工具欄捲動區 / Left toolbox scroll area -->
    <ScrollPane fx:id="toolboxScrollPane"
                layoutX="0.0"
                layoutY="56.0"
                prefWidth="200.0"
                prefHeight="604.0"
                fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                pannable="true"
                style="-fx-background: #FFFFFF;
                       -fx-background-color: #FFFFFF;
                       -fx-border-color: #7ADFFF;
                       -fx-border-width: 0 1 0 0;">

        <content>
            <!-- 左邊積木工具欄 / Left block toolbox -->
            <VBox fx:id="toolbox"
                  spacing="14.0"
                  prefWidth="180.0"
                  style="-fx-background-color: #FFFFFF;
                         -fx-padding: 16;" />
        </content>
    </ScrollPane>

    <!-- 左側積木工具欄滑動按鈕 / Sliding button for the left block toolbox -->
    <!-- 按一下收合，再按一下展開 / Press once to collapse, press again to expand -->
    <Button fx:id="toolboxToggleButton"
            text=">"
            onAction="#handleToggleToolbox"
            layoutX="188.0"
            layoutY="328.0"
            prefWidth="24.0"
            prefHeight="60.0"
            style="-fx-font-family: 'Segoe UI';
                   -fx-font-size: 16;
                   -fx-font-weight: bold;
                   -fx-text-fill: white;
                   -fx-background-color:
                       linear-gradient(to bottom, #72ECFF, #1F9BFF);
                   -fx-background-radius: 0 14 14 0;
                   -fx-border-radius: 0 14 14 0;
                   -fx-border-color: white;
                   -fx-border-width: 1;" />

    <!-- 中間工作區 / Center workspace -->
    <ScrollPane fx:id="workspaceScrollPane"
                layoutX="200.0"
                layoutY="56.0"
                prefWidth="620.0"
                prefHeight="604.0"
                pannable="true"
                fitToWidth="false"
                fitToHeight="false"
                style="-fx-background: #FFFFFF;
                       -fx-background-color: #FFFFFF;">

        <content>
            <!-- 實際可以放積木的工作區 / Actual workspace for blocks -->
            <Pane fx:id="workspace"
                  prefWidth="2000.0"
                  prefHeight="2000.0"
                  style="-fx-background-color: #FFFFFF;
                         -fx-border-color: #7ADFFF;
                         -fx-border-width: 0 1 0 0;">

                <!-- 箭頭圖層：放連線 / Arrow layer: connection lines -->
                <Pane fx:id="arrowLayer"
                      prefWidth="2000.0"
                      prefHeight="2000.0"
                      pickOnBounds="false"
                      style="-fx-background-color: transparent;" />

                <!-- 積木圖層：放拖進來的積木 / Blocks layer: dragged blocks -->
                <Pane fx:id="blocksLayer"
                      prefWidth="2000.0"
                      prefHeight="2000.0"
                      pickOnBounds="false"
                      style="-fx-background-color: transparent;" />

            </Pane>
        </content>
    </ScrollPane>

    <!-- 右邊執行結果區 / Right result area -->
    <Pane fx:id="resultPane"
          layoutX="820.0"
          layoutY="56.0"
          prefWidth="380.0"
          prefHeight="604.0"
          style="-fx-background-color: #FFFFFF;">

        <!-- 執行結果文字 / Run result text -->
        <Label fx:id="resultLabel"
               text="執行結果區"
               layoutX="24.0"
               layoutY="25.0"
               prefWidth="332.0"
               prefHeight="540.0"
               wrapText="true"
               style="-fx-font-family: 'Segoe UI';
                      -fx-font-size: 16;
                      -fx-font-weight: bold;
                      -fx-text-fill: #0B4A6F;" />
    </Pane>

    <!-- 下方狀態列 / Bottom status bar -->
    <Pane fx:id="bottomBar"
          layoutX="0.0"
          layoutY="660.0"
          prefWidth="1200.0"
          prefHeight="40.0"
          style="-fx-background-color:
                    linear-gradient(to bottom, rgba(255,255,255,0.55), rgba(255,255,255,0.85));
                 -fx-border-color: rgba(255,255,255,0.95);
                 -fx-border-width: 1 0 0 0;">

        <!-- 狀態文字 / Status text -->
        <Label text="Ready"
               layoutX="24.0"
               layoutY="10.0"
               style="-fx-font-family: 'Segoe UI';
                      -fx-font-size: 14;
                      -fx-text-fill: #0B4A6F;" />

        <!-- 縮放顯示 / Zoom display -->
        <Label text="Zoom: 100%"
               layoutX="1060.0"
               layoutY="10.0"
               style="-fx-font-family: 'Segoe UI';
                      -fx-font-size: 14;
                      -fx-text-fill: #0B4A6F;" />
    </Pane>

</AnchorPane>
